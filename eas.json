{
  "cli": {
    "version": ">= 16.17.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_USE_POD_INSTALLER": "1",
        "RCT_NEW_ARCH_ENABLED": "1"
      }
    },
    "ios-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_USE_POD_INSTALLER": "1",
        "RCT_NEW_ARCH_ENABLED": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": { "image": "latest" },
      "env": {
        "EXPO_USE_POD_INSTALLER": "1",
        "RCT_NEW_ARCH_ENABLED": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
