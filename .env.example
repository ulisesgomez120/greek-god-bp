# ============================================================================
# TRAINSMART ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env files to version control

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from your Supabase project dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (for server-side operations)
# Only use in secure server environments, never in client code
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# OpenAI API key for AI coaching features
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key


# ============================================================================
# API CONFIGURATION
# ============================================================================
# Base API URL for your backend services
EXPO_PUBLIC_API_URL=https://api.trainsmart.app

# Alternative URLs for different environments
# EXPO_PUBLIC_API_URL=http://localhost:3000  # Local development
# EXPO_PUBLIC_API_URL=https://staging-api.trainsmart.app  # Staging

# ============================================================================
# EXPO & EAS CONFIGURATION
# ============================================================================
# EAS Project ID (get from expo.dev dashboard)
# - Find this in your project settings on https://expo.dev (Projects -> Your project -> Settings).
# - It's required by `eas build` when using the `extra.eas.projectId` configuration above.
EAS_PROJECT_ID=12345678-1234-1234-1234-123456789012

# Expo access token for CI/CD
# - Generate an access token from your Expo account (https://expo.dev/accounts/<your-username>/settings/tokens -> "New Access Token").
# - Use this token for CI systems or when running non-interactive EAS/Expo commands.
# - Locally you can authenticate with `eas login` and verify with `eas whoami`. On CI set EXPO_TOKEN as a secret.
EXPO_TOKEN=your-expo-access-token

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================
# Sentry DSN for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=trainsmart
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Google Analytics measurement ID
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Enable analytics in production
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================
# Environment (development, staging, production)
NODE_ENV=development

# Enable Flipper for debugging (development only)
FLIPPER_ENABLED=true

# Skip onboarding for development
SKIP_ONBOARDING=false

# Mock API responses for testing
MOCK_API_RESPONSES=false

# Debug logging level
LOG_LEVEL=debug

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Encryption key for sensitive data (generate a secure random string)
ENCRYPTION_KEY=your-32-character-encryption-key

# JWT secret for token signing (server-side only)
JWT_SECRET=your-jwt-secret-key

# Session timeout in milliseconds
SESSION_TIMEOUT=3600000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features for testing
FEATURE_AI_COACHING=true
FEATURE_CUSTOM_WORKOUTS=true
FEATURE_COACH_DASHBOARD=false
FEATURE_OFFLINE_SYNC=true
FEATURE_PROGRESSIVE_OVERLOAD=true
FEATURE_REAL_TIME_UPDATES=true
FEATURE_SOCIAL_FEATURES=false
FEATURE_WEARABLE_INTEGRATION=false

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================
# Apple HealthKit (iOS)
HEALTHKIT_ENABLED=true

# Google Fit (Android)
GOOGLE_FIT_ENABLED=true

# Fitness equipment integrations
POLAR_API_KEY=your-polar-api-key
GARMIN_API_KEY=your-garmin-api-key
FITBIT_CLIENT_ID=your-fitbit-client-id

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================
# Netlify site ID for PWA deployment
NETLIFY_SITE_ID=your-netlify-site-id
NETLIFY_AUTH_TOKEN=your-netlify-auth-token

# Vercel deployment token (alternative to Netlify)
VERCEL_TOKEN=your-vercel-token

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Database connection string (if using external database)
DATABASE_URL=postgresql://user:password@host:port/database

# Redis connection string (for caching)
REDIS_URL=redis://user:password@host:port

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Email service configuration (for notifications)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@trainsmart.app

# Alternative email services
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=mg.trainsmart.app

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
# AWS S3 configuration (if using external storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=trainsmart-assets

# Cloudinary configuration (for image processing)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================================================
# TESTING CONFIGURATION
# ============================================================================
# Test database URL
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/trainsmart_test

# Disable external API calls during testing
DISABLE_EXTERNAL_APIS=false

# ============================================================================
# PERFORMANCE MONITORING
# ============================================================================
# New Relic license key
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key

# DataDog API key
DATADOG_API_KEY=your-datadog-api-key

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
# Backup storage configuration
BACKUP_S3_BUCKET=trainsmart-backups
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# ============================================================================
# RATE LIMITING
# ============================================================================
# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# API rate limits per user tier
FREE_TIER_RATE_LIMIT=10
PREMIUM_TIER_RATE_LIMIT=100
COACH_TIER_RATE_LIMIT=500

# ============================================================================
# CONTENT DELIVERY
# ============================================================================
# CDN configuration
CDN_URL=https://cdn.trainsmart.app
CDN_API_KEY=your-cdn-api-key

# Image optimization service
IMAGE_OPTIMIZATION_SERVICE=cloudinary
# IMAGE_OPTIMIZATION_SERVICE=imagekit

# ============================================================================
# COMPLIANCE & PRIVACY
# ============================================================================
# Privacy compliance settings
GDPR_COMPLIANCE=true
CCPA_COMPLIANCE=true
HIPAA_COMPLIANCE=false

# Data retention periods (in days)
USER_DATA_RETENTION=2555  # 7 years
WORKOUT_DATA_RETENTION=1825  # 5 years
LOG_DATA_RETENTION=90  # 3 months

# ============================================================================
# LOCALIZATION
# ============================================================================
# Default language and supported locales
DEFAULT_LOCALE=en-US
SUPPORTED_LOCALES=en-US,es-ES,fr-FR,de-DE,pt-BR

# Translation service
TRANSLATION_SERVICE_API_KEY=your-translation-api-key
